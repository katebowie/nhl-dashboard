# function to download and process files
```{r}

process_run <- function(run_root_arg, latest_files_arg, tmp_dir_arg = "./tmp_downloads", bucket_arg = "nao-mgs-stable") {

  # Create a local folder for this run
  local_run <- file.path(tmp_dir_arg, run_root_arg)
  if(dir.exists(local_run)) unlink(local_run, recursive = TRUE)
  dir.create(local_run, recursive = TRUE, showWarnings = FALSE)

  latest_version_path <- latest_files_arg %>%
    filter(run_root == run_root_arg) %>%
    pull(Key) %>%
    dirname() %>%
    unique() %>%
    sub("output/results/.*$", "output/results/", .)

  if(length(latest_version_path) != 1) {
    stop("Could not find a unique results folder for run: ", run_root_arg)
  }

  message("Downloading run ", run_root_arg, " from ", latest_version_path)

  # Download only the 3 files we need
  cmd <- paste0(
    "aws s3 sync s3://", bucket_arg, "/", latest_version_path, " ", local_run,
    " --exclude '*' ",
    "--include 'kraken_reports_merged*' ",
    "--include 'virus_hits_final*' ",
    "--include 'read_counts*' ",
    "--exact-timestamps --no-progress"
  )
  system(cmd)

  kraken_file <- list.files(local_run, pattern = "^kraken_reports_merged.*\\.tsv(\\.gz)?$", full.names = TRUE, recursive = TRUE)
  virus_file  <- list.files(local_run, pattern = "^virus_hits_final.*\\.tsv(\\.gz)?$", full.names = TRUE, recursive = TRUE)
  reads_file  <- list.files(local_run, pattern = "^read_counts.*\\.tsv(\\.gz)?$", full.names = TRUE, recursive = TRUE)

  stopifnot(length(kraken_file) == 1, length(virus_file) == 1, length(reads_file) == 1)

  # Read the files freshly for this run
  kraken <- fread(kraken_file, select = c("sample", "ribosomal", "n_reads_direct"))
  virus  <- fread(virus_file,  select = "sample")
  reads  <- fread(reads_file,  select = c("sample", "n_read_pairs"))

  # Add run column
  kraken[, run := run_root_arg]
  virus[, run := run_root_arg]
  reads[, run := run_root_arg]

  # Summarize kraken and virus reads per sample/run
  kraken_summary <- kraken[, .(
    ribo_reads = sum(n_reads_direct[ribosomal == TRUE], na.rm = TRUE),
    nonribo_reads = sum(n_reads_direct[ribosomal == FALSE], na.rm = TRUE)
  ), by = .(sample, run)]

  virus_summary <- virus[, .(viral_reads = .N), by = .(sample, run)]

  # Merge tables by both sample and run
  row_df <- kraken_summary %>%
    full_join(virus_summary, by = c("sample", "run")) %>%
    full_join(reads, by = c("sample", "run")) %>%
    mutate(sample_basename = str_remove(sample, "_S\\d+_L\\d+$")) %>%
    group_by(run, sample_basename) %>%
    summarise(across(c(viral_reads, ribo_reads, nonribo_reads, n_read_pairs),
                     sum, na.rm = TRUE), .groups = "drop") %>%
    mutate(
      ribo_frac  = ribo_reads / (ribo_reads + nonribo_reads) * 100,
      viral_frac = viral_reads / n_read_pairs * 100,
      other      = 100 - (ribo_frac + viral_frac)
    )

  # Clean up temp folder for this run
  unlink(local_run, recursive = TRUE)

  return(row_df)
}

```


### running it as chunks
Time 7:39 -->10:14  (previously it took over 2 hours for only 20 samples, so this feels like a win)
```{r}

chunk_size <- 6
run_chunks <- split(run_roots, ceiling(seq_along(run_roots)/chunk_size))

plan(multisession, workers = chunk_size)

all_results <- list()

for(chunk in run_chunks) {
  message("Processing chunk: ", paste(chunk, collapse = ", "))
  chunk_results <- future_map(chunk, process_run, latest_files = latest_files, tmp_dir = tmp_dir)
  all_results <- c(all_results, chunk_results)
}

# Combine all runs
all_runs_df <- bind_rows(all_results)

```


# clean up
```{r}

