# Linear Modeling
```{r}
library(lme4)

model_df <- all_frac %>% 
  filter(state != "Wisconsin" & loc_id != "MO_KC_BlueRiverNEID")

m1 <- lmer(log10(viral_reads) ~ log10(ribo_reads) + (1 | loc_id), offset = log10(n_read_pairs), data = model_df)

summary(m1)

```


# Looking at ICC
Intraclass correlation coefficient --> fraction of total variance in viral recovery that is explained by differences between plants.
```{r}

library(performance)

icc(m1)

```


### checking model fit
All residuals are clustered around 0 with no clear pattern so I feel pretty ok about using linear model here. 
```{r}

residuals <- resid(m1)
fitted <- predict(m1, re.form = NA)

ggplot(data.frame(fitted, residuals), aes(x = fitted, y = residuals)) +
  geom_point(alpha = 0.5) +
  geom_hline(yintercept = 0, linetype = "dashed") +
  labs(x = "Fitted values (log10 viral reads)", y = "Residuals") +
  theme_bw()


```


## adding confidence intervals
```{r}

# Extract random effects and their SEs
re <- ranef(m1)$loc_id
se <- se.ranef(m1)$loc_id

re_df <- re %>%
  tibble::rownames_to_column("loc_id") %>%
  rename(effect = `(Intercept)`) %>%
  mutate(se = se[,"(Intercept)"],
    lower = effect - 1.96 * se,
    upper = effect + 1.96 * se,
    performance = case_when(
      effect > 0 ~ "Better than average",
      effect < 0 ~ "Worse than average"))


```



# Summary of effects from each site
```{r}

ggplot(re_df, aes(x = reorder(loc_id, effect), y = effect, color = performance)) +
  geom_pointrange(aes(ymin = lower, ymax = upper), size = .8) +
  coord_flip() +
  geom_hline(yintercept = 0, linetype = "dashed") +
  scale_color_manual(values = c("Better than average" = "#2C7BB6", "Worse than average"  = "#D7191C")) +
  theme_bw() +
  labs(x = "Wastewater treatment plant",
    y = "Baseline viral recovery (log10 deviation,\nadjusted for ribosomal RNA and sequencing depth)", color = "")

